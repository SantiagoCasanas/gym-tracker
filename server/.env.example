# --- Base de datos (PostgreSQL) ---
# Local: apunta a tu Postgres local. En Render se inyecta automáticamente
# desde la base de datos del blueprint (render.yaml), no lo definas a mano allí.
DATABASE_URL="postgresql://postgres:password@localhost:5433/gymtracker?schema=public"

# Puerto HTTP. En Render se inyecta automáticamente (usa process.env.PORT).
PORT=4000

# Secreto para firmar los JWT. En Render se genera automáticamente.
JWT_SECRET=change-me-to-a-random-secret

# URL pública del frontend (se usa en los links de invitación por correo).
APP_URL=http://localhost:5180

# Orígenes permitidos por CORS (coma-separado). Si se deja vacío, se usa
# APP_URL y http://localhost:5180 como fallback.
CORS_ORIGIN=http://localhost:5180

# --- Admin sembrado al arrancar (idempotente) ---
ADMIN_EMAIL=admin@gymtracker.local
ADMIN_PASSWORD=Admin1234
ADMIN_NAME=Admin

# --- Brevo (API HTTP para correo transaccional) ---
# Render bloquea SMTP saliente, por eso usamos la API HTTP de Brevo.
# Si BREVO_API_KEY se deja vacío, el envío se omite (no-op) y el link de
# invitación queda en el panel admin / logs como respaldo.
BREVO_API_KEY=
# Remitente verificado en Brevo (obligatorio para enviar).
MAIL_FROM=
MAIL_FROM_NAME=Gym Tracker

# --- Google login (solo invitados) ---
# Client ID (Web) del proyecto de Google Cloud. La web usa VITE_GOOGLE_CLIENT_ID.
# Si se deja vacío, POST /auth/google responde 503.
GOOGLE_CLIENT_ID=

# --- Gmail SMTP (legacy, ya no lo usa el mailer; se conserva por compatibilidad) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
